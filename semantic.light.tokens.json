{
  "color": {
    "bg": {
      "default": { "$type": "color", "$value": "{palette.white}" },
      "subtle":  { "$type": "color", "$value": "{palette.gray.50}" },
      "muted":   { "$type": "color", "$value": "{palette.gray.100}" }
    },
    "text": {
      "default": { "$type": "color", "$value": "{palette.gray.900}" },
      "muted":   { "$type": "color", "$value": "{palette.gray.600}" },
      "onAction":{ "$type": "color", "$value": "{palette.white}" }
    },
    "action": {
      "primary":       { "$type": "color", "$value": "{palette.blue.600}" },
      "primary-hover": { "$type": "color", "$value": "{palette.blue.700}" }
    },
    "border": {
      "default": { "$type": "color", "$value": "{palette.gray.200}" },
      "strong":  { "$type": "color", "$value": "{palette.gray.400}" }
    }
  }
}
