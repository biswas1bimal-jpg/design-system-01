{
  "//": "Type styles mirrored from the Figma local text styles 'Typography — Geist'.",
  "//weights": "Geist: Regular 400, Medium 500, SemiBold 600, Bold 700. lineHeight is unitless (× font-size); Figma stores it as a percent.",
  "fontFamily": "Geist, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
  "styles": {
    "display":      { "weight": 700, "size": 36, "lineHeight": 1.15, "figma": "Display" },
    "heading-h1":   { "weight": 600, "size": 30, "lineHeight": 1.2,  "figma": "Heading/H1" },
    "heading-h2":   { "weight": 600, "size": 24, "lineHeight": 1.25, "figma": "Heading/H2" },
    "heading-h3":   { "weight": 600, "size": 20, "lineHeight": 1.3,  "figma": "Heading/H3" },
    "heading-h4":   { "weight": 600, "size": 16, "lineHeight": 1.35, "figma": "Heading/H4" },
    "heading-h5":   { "weight": 600, "size": 14, "lineHeight": 1.4,  "figma": "Heading/H5" },
    "body-large":   { "weight": 400, "size": 18, "lineHeight": 1.5,  "figma": "Body/Large" },
    "body-default": { "weight": 400, "size": 16, "lineHeight": 1.5,  "figma": "Body/Default" },
    "body-small":   { "weight": 400, "size": 14, "lineHeight": 1.5,  "figma": "Body/Small" },
    "label":        { "weight": 500, "size": 14, "lineHeight": 1.4,  "figma": "Label" },
    "label-large":  { "weight": 500, "size": 16, "lineHeight": 1.4,  "figma": "Label/Large" },
    "label-xl":     { "weight": 500, "size": 18, "lineHeight": 1.4,  "figma": "Label/XL" },
    "caption":      { "weight": 400, "size": 12, "lineHeight": 1.4,  "figma": "Caption" },
    "extra-small":  { "weight": 500, "size": 9,  "lineHeight": 1.4,  "figma": "Extra small" },
    "strong-sm":    { "weight": 700, "size": 12, "lineHeight": 1.2,  "figma": "Strong/SM" },
    "strong-md":    { "weight": 700, "size": 14, "lineHeight": 1.2,  "figma": "Strong/MD" },
    "strong-lg":    { "weight": 700, "size": 20, "lineHeight": 1.2,  "figma": "Strong/LG" }
  }
}
